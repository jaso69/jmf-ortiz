{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/generar-docx/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/html-docx/?$",
			"dest": "_render"
		},
		{
			"src": "^/audio/?$",
			"dest": "_render"
		},
		{
			"src": "^/chat/?$",
			"dest": "_render"
		},
		{
			"src": "^/chat(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/legal/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/legal/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy-policy/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/services(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/style-guide/?$",
			"dest": "_render"
		},
		{
			"src": "^/theme-info/TechSpecs/?$",
			"dest": "_render"
		},
		{
			"src": "^/theme-info/?$",
			"dest": "_render"
		},
		{
			"src": "^/verify/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}