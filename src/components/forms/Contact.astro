<div class="jmf-contact-chat" id="jmf-contact-chat">
    <div class="jmf-contact-chat__header">
        <div class="jmf-contact-chat__avatar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
        </div>
        <div class="jmf-contact-chat__header-info">
            <h3>JMF Ortiz</h3>
            <span class="jmf-contact-chat__status">
                <span class="jmf-contact-chat__status-dot"></span>
                En línea
            </span>
        </div>
    </div>

    <div class="jmf-contact-chat__messages" id="jmf-contact-messages">
    </div>

    <div class="jmf-contact-chat__footer">
        <div class="jmf-contact-chat__typing" id="jmf-contact-typing">
            <span></span><span></span><span></span>
        </div>
        <form id="jmf-contact-form" class="jmf-contact-chat__input-wrap">
            <input type="text" id="jmf-contact-input" placeholder="Escribe tu consulta..." autocomplete="off" />
            <button type="submit" id="jmf-contact-send" aria-label="Enviar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        </form>
    </div>
</div>

<script>
(function() {
    const WEBHOOK_URL = 'https://jmfortiz.jasodev.es/webhook/77abf0dd-4cdf-4984-9682-8caec2373b93';
    const SESSION_KEY = 'jmf_chat_session';

    let sessionId = localStorage.getItem(SESSION_KEY);
    if (!sessionId) {
        sessionId = 'sess_' + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
        localStorage.setItem(SESSION_KEY, sessionId);
    }

    function formatTime(d: Date) {
        return d.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
    }

    function escapeHtml(t: string) {
        const d = document.createElement('div');
        d.textContent = t;
        return d.innerHTML;
    }

    function scrollDown() {
        const el = document.getElementById('jmf-contact-messages');
        if (el) setTimeout(() => el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' }), 50);
    }

    function createBotMsg() {
        const wrap = document.getElementById('jmf-contact-messages');
        if (!wrap) return null;

        const row = document.createElement('div');
        row.className = 'jmf-contact-msg jmf-contact-msg--bot';

        row.innerHTML =
            '<div class="jmf-contact-msg__avatar">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">' +
                    '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>' +
                    '<circle cx="12" cy="7" r="4"/>' +
                '</svg>' +
            '</div>' +
            '<div class="jmf-contact-msg__body">' +
                '<p class="jmf-contact-msg__text"></p>' +
                '<span class="jmf-contact-msg__time">' + formatTime(new Date()) + '</span>' +
            '</div>';

        wrap.appendChild(row);
        scrollDown();
        return row.querySelector('.jmf-contact-msg__text') as HTMLElement | null;
    }

    function createUserMsg(text: string) {
        const wrap = document.getElementById('jmf-contact-messages');
        if (!wrap) return;

        const row = document.createElement('div');
        row.className = 'jmf-contact-msg jmf-contact-msg--user';

        row.innerHTML =
            '<div class="jmf-contact-msg__body">' +
                '<p>' + escapeHtml(text) + '</p>' +
                '<span class="jmf-contact-msg__time">' + formatTime(new Date()) + '</span>' +
            '</div>';

        wrap.appendChild(row);
        scrollDown();
    }

    async function send(text: string) {
        const typing = document.getElementById('jmf-contact-typing');
        if (typing) typing.style.display = 'flex';

        createUserMsg(text);

        const input = document.getElementById('jmf-contact-input') as HTMLInputElement | null;
        if (input) input.value = '';

        try {
            const res = await fetch(WEBHOOK_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: text,
                    sessionId: sessionId,
                    timestamp: new Date().toISOString()
                })
            });

            if (typing) typing.style.display = 'none';

            if (!res.ok) throw new Error('HTTP ' + res.status);

            const textEl = createBotMsg();
            if (!textEl) return;

            const reader = res.body?.getReader();
            if (!reader) {
                textEl.textContent = await res.text();
                scrollDown();
                return;
            }

            const decoder = new TextDecoder();
            let output = '';
            let done = false;

            while (!done) {
                const chunk = await reader.read();
                done = chunk.done;
                if (done) break;

                const str = decoder.decode(chunk.value, { stream: true });
                const lines = str.split('\n');

                for (const line of lines) {
                    const trimmed = line.trim();
                    if (!trimmed || trimmed === '0') continue;

                    try {
                        const data = JSON.parse(trimmed);

                        if (data.type === 'item' && data.content) {
                            if (data.metadata?.nodeName === 'Respond to Webhook') {
                                try {
                                    const parsed = JSON.parse(data.content);
                                    output = parsed.output || data.content;
                                } catch {
                                    output = data.content;
                                }
                            } else {
                                output += data.content;
                            }
                            textEl.textContent = output;
                            scrollDown();
                        }

                        if (data.type === 'end' && data.metadata?.nodeName === 'Respond to Webhook') {
                            done = true;
                            break;
                        }
                    } catch {}
                }
            }

            if (!textEl.textContent && output) {
                textEl.textContent = output;
            }
            scrollDown();

        } catch (err) {
            if (typing) typing.style.display = 'none';
            const errEl = createBotMsg();
            if (errEl) errEl.textContent = 'Lo siento, ha ocurrido un error. Inténtalo de nuevo.';
            console.error('Chat error:', err);
        }
    }

    function init() {
        const wrap = document.getElementById('jmf-contact-messages');
        if (wrap) {
            const row = document.createElement('div');
            row.className = 'jmf-contact-msg jmf-contact-msg--bot';
            row.innerHTML =
                '<div class="jmf-contact-msg__avatar">' +
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">' +
                        '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>' +
                        '<circle cx="12" cy="7" r="4"/>' +
                    '</svg>' +
                '</div>' +
                '<div class="jmf-contact-msg__body">' +
                    '<p class="jmf-contact-msg__text">Administrador virtual JMF Ortiz a tu servicio. ¿En qué puedo ayudarte hoy?</p>' +
                    '<span class="jmf-contact-msg__time">' + formatTime(new Date()) + '</span>' +
                '</div>';
            wrap.appendChild(row);
        }

        const form = document.getElementById('jmf-contact-form');
        const input = document.getElementById('jmf-contact-input') as HTMLInputElement | null;

        if (form && input) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const val = input.value.trim();
                if (val) send(val);
            });
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>

