---
import Layout from "@layouts/Layout.astro"
import InnerHero from "@components/sections/InnerHero.astro"
import ContactInfo from "@components/sections/ContactInfo.astro"

const heroContent = {
    title: "Contáctanos",
    description: "Ponte en contacto con JMF Ortiz para resolver tus dudas sobre administración de fincas en Torrejón de Ardoz."
}
---

<Layout title="Contáctanos" description="Ponte en contacto con JMF Ortiz. Más de 40 años de experiencia en administración de fincas en Torrejón de Ardoz. Teléfono, email y asistente virtual.">
    <InnerHero content={heroContent} />
    <ContactInfo background="base" padding="base" />
</Layout>
