---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import Stats from '@components/sections/Stats.astro';
import { featureLists } from '@data/features';
import { statsLists } from '@data/stats';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import heroImage from '../assets/images/home/hero.webp';
import styleGuideImage from '../assets/images/home/dev.webp';
// 81.88.48.71
const seoTitle = "Administradores de fincas JMF Ortiz";
const seoDescription = "Administradores de Fincas en Torrejón de Ardoz con más de 40 años de experiencia. Presupuesto gratuito y sin compromiso."

const heroContent = {
    title: 'Administradores de Fincas JMF Ortiz',
    description: 'Gestión integral de comunidades de propietarios en Torrejón de Ardoz y Madrid. Más de 40 años de experiencia al servicio de su finca.',
    buttons: [
        {
            text: 'Solicitar presupuesto',
            link: '/contact',
            target: '_self'
        },
        {
            text: 'Hablar con nuestro asistente',
            link: '/chat',
            target: '_self'
        }
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.25,
    badge: 'Más de 40 años de experiencia'
}

const featuresSection = {
    eyebrow: "",
    title: "Gestión de fincas en Torrejón de Ardoz",
    description: "Somos una empresa familiar especializada en la administración y mantenimiento integral de comunidades de propietarios. Ofrecemos un servicio cercano, transparente y de alta calidad.",
    features: featureLists.main.features,
    button: {
        text: "Resolver dudas con nuestro asistente",
        link: "/chat",
        variant: "primary" as const
    }
}

const FooterCta = {
    eyebrow: "",
    title: 'Contacte con la administración de fincas',
    description: 'Ponemos a su disposición teléfono con centralita, formulario de contacto y un asistente virtual para atender sus consultas con la mayor diligencia.',
    hideCta: false,
    button: {
        text: 'Contactar',
        link: '/contact',
        target: '_self'
    }
}

const styleGuideSection = {
    eyebrow: "",
    headline: "Gestión integral de su comunidad",
    description: "Nos encargamos de la contabilidad, gestión de cobros, contratación de servicios, mantenimiento de instalaciones y cualquier otro trámite que precise su comunidad.",
    image: {
        src: styleGuideImage,
        alt: "Equipo de administradores de fincas revisando documentación y planificación de servicios"
    },
    buttons: [
        {
            text: "Servicios que ofrecemos",
            link: "/services",
            variant: "primary" as const
        }
    ]
}

const sideBySideStats = {
    eyebrow: "",
    title: "Experiencia y profesionalidad",
    description: "Desde hace más de cuatro décadas somos especialistas en gestión y administración de fincas, aportando confianza y tranquilidad a las comunidades de propietarios de Torrejón de Ardoz y Madrid.",
    variant: 'side-by-side' as const,
    stats: statsLists.withContent.stats,
    content: {
        title: "Un equipo a su servicio",
        description: "Cada miembro de nuestro equipo está comprometido con la calidad, la transparencia y una atención personalizada. Tratamos cada comunidad como si fuera nuestra.",
    }
};

const faqsSection = {
    eyebrow: "FAQs",
    title: 'Preguntas Frecuentes',
    description: 'Encuentra respuestas a las preguntas más comunes sobre nuestra Administración y servicios.',
    faqs: faqLists.main.faqs
}
---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="base" background="base" />
    <SplitPanel content={styleGuideSection} imagePosition="right" background="light" padding="base" />
    <Stats content={sideBySideStats} background='base' padding="base"/>
    <Faqs content={faqsSection} background="light" padding="base" />
</Layout>
